<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Detail – LittleBom</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@300;400;600;700&display=swap">
  <style>
    :root{--primary:#8b5e3c;--bg:#faf9f7;--surface:#f0ede8;--border:#e8e4df;--text:#2c2c2c;--muted:#8a8680;--font-h:'Playfair Display',serif;--font-b:'Lato',sans-serif}
    body{font-family:var(--font-b);background:var(--bg);color:var(--text);font-size:14px}
    .navbar-custom{background:var(--bg);padding:20px 48px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
    .navbar-brand-text{font-family:var(--font-h);font-size:1.35rem;font-weight:700;color:var(--text);text-decoration:none}
    .navbar-icons a{color:var(--text);font-size:1.1rem;text-decoration:none;margin-left:20px}
    .page-wrap{padding:32px 48px 60px;max-width:900px;margin:0 auto}
    .back-link{color:var(--muted);text-decoration:none;font-size:.82rem;display:inline-flex;align-items:center;gap:5px;margin-bottom:20px}
    .back-link:hover{color:var(--primary)}
    .card{background:#fff;border-radius:16px;border:1px solid var(--border);padding:24px;margin-bottom:20px}
    .card-title{font-family:var(--font-h);font-size:1rem;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px}
    .card-title i{color:var(--primary)}

    /* TRACKING */
    .tracking-steps{display:flex;justify-content:space-between;position:relative;margin:10px 0 24px}
    .tracking-steps::before{content:'';position:absolute;top:20px;left:0;right:0;height:2px;background:var(--border);z-index:0}
    .step{display:flex;flex-direction:column;align-items:center;gap:8px;z-index:1;flex:1}
    .step-circle{width:40px;height:40px;border-radius:50%;background:var(--surface);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--muted)}
    .step-circle.active{background:var(--primary);border-color:var(--primary);color:#fff}
    .step-circle.done{background:#2d7a5a;border-color:#2d7a5a;color:#fff}
    .step-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);text-align:center}
    .step-label.active{color:var(--primary)}
    .step-label.done{color:#2d7a5a}

    /* ITEMS */
    .order-item{display:flex;gap:14px;padding:12px 0;border-bottom:1px solid var(--surface);align-items:center}
    .order-item:last-child{border-bottom:none}
    .item-img{width:56px;height:56px;border-radius:8px;object-fit:cover;background:var(--surface);flex-shrink:0}
    .item-name{font-weight:700;font-size:.86rem}
    .item-qty{font-size:.78rem;color:var(--muted)}
    .item-price{font-weight:700;font-size:.88rem;color:var(--primary);white-space:nowrap;margin-left:auto}

    /* ADDRESS */
    .addr-text{font-size:.84rem;line-height:1.8;color:var(--muted)}
    .addr-name{font-weight:700;margin-bottom:4px}

    /* SUMMARY */
    .summary-row{display:flex;justify-content:space-between;font-size:.85rem;margin-bottom:8px;color:var(--muted)}
    .summary-row span:last-child{color:var(--text);font-weight:600}
    .summary-total{display:flex;justify-content:space-between;font-weight:700;font-size:1rem;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}
    .summary-total span:last-child{color:var(--primary)}

    /* ACTIONS */
    .action-btn{padding:10px 24px;border-radius:50px;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;border:none;cursor:pointer}
    .btn-cancel{background:#fdedec;color:#c0392b}
    .btn-cancel:hover{background:#c0392b;color:#fff}
    .btn-return{background:#f4ecf7;color:#7d3c98}
    .btn-return:hover{background:#7d3c98;color:#fff}

    @media(max-width:768px){.navbar-custom,.page-wrap{padding-left:20px;padding-right:20px}.tracking-steps{gap:4px}}
  </style>
</head>
<body>

<nav class="navbar-custom">
  <a href="/" class="navbar-brand-text">LittleBom</a>
  <div class="navbar-icons">
    <a href="/home"><i class="bi bi-house"></i></a>
    <a href="/cart"><i class="bi bi-bag"></i></a>
    <a href="/profile"><i class="bi bi-person"></i></a>
    <a href="/logout"><i class="bi bi-box-arrow-right"></i></a>
  </div>
</nav>

<div class="page-wrap">
  <a href="/orders" class="back-link"><i class="bi bi-arrow-left"></i> Back to Orders</a>

  <!-- ORDER TRACKING -->
  <div class="card">
    <div class="card-title"><i class="bi bi-geo-alt"></i> Order Tracking</div>
    <%
      const steps = ['placed','processing','shipped','delivered']
      const currentIndex = steps.indexOf(order.orderStatus)
    %>
    <div class="tracking-steps">
      <% steps.forEach((step, index) => { %>
        <div class="step">
          <div class="step-circle <%= index < currentIndex ? 'done' : index === currentIndex ? 'active' : '' %>">
            <% if(index < currentIndex) { %>
              <i class="bi bi-check"></i>
            <% } else { %>
              <%= index + 1 %>
            <% } %>
          </div>
          <div class="step-label <%= index < currentIndex ? 'done' : index === currentIndex ? 'active' : '' %>">
            <%= step %>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- CANCEL / RETURN BUTTONS -->
    <div style="margin-top:8px">
      <% if(order.orderStatus === 'placed' || order.orderStatus === 'processing') { %>
        <button class="action-btn btn-cancel" onclick="cancelOrder('<%= order._id %>')">
          <i class="bi bi-x-circle"></i> Cancel Order
        </button>
      <% } %>
      <% if(order.orderStatus === 'delivered') { %>
        <button class="action-btn btn-return" onclick="returnOrder('<%= order._id %>')">
          <i class="bi bi-arrow-return-left"></i> Return Order
        </button>
      <% } %>
    </div>
  </div>

  <!-- ORDER ITEMS -->
  <div class="card">
    <div class="card-title"><i class="bi bi-bag-check"></i> Order Items</div>
    <% order.items.forEach(item => { %>
    <div class="order-item">
      <img class="item-img" src="<%= item.image %>" alt="<%= item.name %>">
      <div>
        <div class="item-name"><%= item.name %></div>
        <div class="item-qty">Qty: <%= item.quantity %></div>
      </div>
      <div class="item-price">₹<%= item.price %></div>
    </div>
    <% }) %>
  </div>

  <!-- DELIVERY ADDRESS -->
  <div class="card">
    <div class="card-title"><i class="bi bi-geo-alt"></i> Delivery Address</div>
    <div class="addr-name"><%= order.address.name %></div>
    <div class="addr-text">
      <%= order.address.house %>, <%= order.address.city %>,<br>
      <%= order.address.state %> – <%= order.address.pincode %><br>
      <i class="bi bi-phone" style="font-size:.72rem"></i> <%= order.address.mobile %>
    </div>
  </div>

  <!-- ORDER SUMMARY -->
  <div class="card">
    <div class="card-title"><i class="bi bi-receipt"></i> Order Summary</div>
    <div class="summary-row"><span>Order ID</span><span>#<%= order._id.toString().slice(-8).toUpperCase() %></span></div>
    <div class="summary-row"><span>Date</span><span><%= new Date(order.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span></div>
    <div class="summary-row"><span>Payment</span><span><%= order.paymentMethod === 'cod' ? 'Cash on Delivery' : 'Razorpay' %></span></div>
    <div class="summary-row"><span>Payment Status</span><span><%= order.paymentStatus %></span></div>
    <div class="summary-row"><span>Subtotal</span><span>₹<%= order.subtotal %></span></div>
    <div class="summary-row"><span>Shipping</span><span>₹<%= order.shipping %></span></div>
    <div class="summary-total"><span>Total</span><span>₹<%= order.grandTotal %></span></div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/user/orderDetail.js"></script>
</body>
</html>
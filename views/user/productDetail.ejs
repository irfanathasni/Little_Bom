<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= product.name %> - Little Bom</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@300;400;600&display=swap" rel="stylesheet">

  <style>

    :root {
      --color-primary: #8b5e3c;
      --color-bg: #faf9f7;
      --color-surface: #f0ede8;
      --color-border: #e8e4df;
      --color-text: #2c2c2c;
      --color-muted: #8a8680;
      --font-heading: 'Playfair Display', serif;
      --font-body: 'Lato', sans-serif;
      --radius-card: 18px;
      --transition: 0.25s ease;
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
    }

    /* ── NAVBAR ── */

    .navbar-custom {
      background: var(--color-bg);
      padding: 20px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--color-border);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .navbar-brand-text {
      font-family: var(--font-heading);
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--color-text);
      text-decoration: none;
    }

    .navbar-links {
      display: flex;
      gap: 36px;
    }

    .navbar-links a {
      text-decoration: none;
      color: var(--color-muted);
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 600;
      transition: color var(--transition);
    }

    .navbar-links a:hover,
    .navbar-links a.active {
      color: var(--color-primary);
    }

    .navbar-links a.active {
      border-bottom: 2px solid var(--color-primary);
      padding-bottom: 2px;
    }

    .navbar-icons {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .navbar-icons a {
      color: var(--color-text);
      font-size: 1.15rem;
      text-decoration: none;
      transition: color var(--transition);
    }

    .navbar-icons a:hover {
      color: var(--color-primary);
    }

    /* ── BREADCRUMB ── */

    .breadcrumb-wrap{
      padding: 24px 48px 0;
    }

    .breadcrumb{
      margin:0;
      font-size:0.8rem;
    }

    .breadcrumb-item a{
      color: var(--color-muted);
      text-decoration:none;
    }

    .breadcrumb-item.active{
      color: var(--color-text);
      font-weight:600;
    }

    /* ── PRODUCT SECTION ── */

    .product-section{
      padding: 36px 48px 70px;
    }

   .product-image-wrapper{
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #f5f3ef;
    height: 560px;

    display: flex;
    align-items: center;
    justify-content: center;
    }

   .product-image-wrapper img{
    height:560px;
    }
    /* ── PRODUCT INFO ── */

    .product-info{
      padding-left:44px;
      padding-top:10px;
    }

    .product-name{
      font-family: var(--font-heading);
      font-size:2.8rem;
      font-weight:700;
      line-height:1.1;
      margin-bottom:16px;
    }

    .product-price{
      font-size:1.45rem;
      color: var(--color-primary);
      margin-bottom:24px;
      font-weight:600;
    }

    .product-description{
      font-size:0.92rem;
      color: var(--color-muted);
      line-height:1.9;
      margin-bottom:40px;
      max-width:500px;
    }

    /* Carousel */
    .carousel{
        width:100%;
        height: auto;
    }

    .carousel-inner{
       height :auto;
    }

    .carousel-item{
        height:auto;
    }

    .carousel-item img{
        height:100vh;
        width: 100%;
        object-fit:cover;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
    background-color: #8b5e3c; /* your theme color */
    border-radius: 50%;
    padding: 18px;
      }
    .zoom-wrapper {
      position: relative;
      cursor: crosshair;
    }

    .zoom-lens {
      position: absolute;
      border: 2px solid var(--color-primary);
      width: 120px;
      height: 120px;
      pointer-events: none;
      display: none;
      border-radius: 50%;
    }

    .zoom-result {
      position: fixed;
      top: 0;
      left: 105%;
      width: 400px;
      height: 400px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
      background-repeat: no-repeat;
      display: none;
      z-index: 10;
    }

    /* ── BUTTON ── */

    .btn-add-cart{
      background: var(--color-primary);
      color:white;
      border:none;
      border-radius:50px;
      padding:18px 0;
      font-size:0.82rem;
      letter-spacing:2px;
      text-transform:uppercase;
      font-weight:700;
      width:100%;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      transition:all var(--transition);
    }

    .btn-add-cart:hover{
      background:#74492d;
      color:white;
    }

    /* ── FOOTER ── */

    footer {
      background: var(--color-surface);
      padding: 56px 48px 32px;
      border-top: 1px solid var(--color-border);
    }

    .footer-brand {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .footer-tagline {
      font-size: 0.8rem;
      color: var(--color-muted);
      font-weight: 300;
      line-height: 1.6;
    }

    .footer-heading {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 700;
      margin-bottom: 18px;
    }

    .footer-links {
      list-style:none;
      padding:0;
    }

    .footer-links li{
      margin-bottom:12px;
    }

    .footer-links a{
      text-decoration:none;
      color: var(--color-muted);
      font-size:0.84rem;
    }

    .footer-links a:hover{
      color: var(--color-primary);
    }

    /* ── RESPONSIVE ── */

    @media(max-width:991px){

      .navbar-custom,
      .breadcrumb-wrap,
      .product-section,
      footer{
        padding-left:24px;
        padding-right:24px;
      }

      .product-info{
        padding-left:0;
        padding-top:40px;
      }
    }

    @media(max-width:767px){

      .navbar-links{
        display:none;
      }

      .product-image-wrapper img{
        height:420px;
      }

      .product-name{
        font-size:2rem;
      }
    }

  </style>
</head>

<body>

<!-- NAVBAR -->

<nav class="navbar-custom">

  <a href="/" class="navbar-brand-text">Little Bom</a>

  <div class="navbar-links">
    <a href="/home">HOME</a>
    <a href="/shop" class="active">SHOP</a>
  </div>

  <div class="navbar-icons">
    <a href="/cart"><i class="bi bi-bag"></i></a>
    <a href="/profile"><i class="bi bi-person"></i></a>
    <a href="/logout"><i class="bi bi-box-arrow-right"></i></a>
  </div>

</nav>

<!-- BREADCRUMB -->

<div class="breadcrumb-wrap">

  <nav aria-label="breadcrumb">

    <ol class="breadcrumb">

      <li class="breadcrumb-item">
        <a href="/shop">Shop</a>
      </li>

      <li class="breadcrumb-item active">
        <%= product.name %>
      </li>

    </ol>

  </nav>

</div>

<!-- PRODUCT DETAIL -->
<section class="product-section">
  <div class="row g-0 align-items-start">
    <!-- IMAGE -->
    <div class="col-lg-7">
        <div id="carouselExample" class="carousel slide">
           <div class="carousel-inner"><% product.image.forEach((img, index) => { %>
           <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
             <div class="zoom-wrapper">
               <div class="zoom-lens"></div>
                <img src="<%= img %>" class="d-block w-100 product-img" alt="<%= product.name %>">
              <div class="zoom-result"></div>
            </div>
          </div>
         <% }) %>
    </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>

    </div>

    <!-- INFO -->

    <div class="col-lg-5">

      <div class="product-info">

        <h1 class="product-name">
          <%= product.name %>
        </h1>

        <p class="product-price">
          ₹<%= product.price.toFixed(2) %>
        </p>

        <p class="product-description">
          <%= product.description %>
        </p>

        <!-- ADD TO CART -->
      <button class="btn-add-cart"  id="addToCartBtn" data-product-id="<%= product._id %>">
        <i class="bi bi-bag"></i>Add To Cart</button>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->

<footer>

  <div class="row g-4 mb-2">

    <div class="col-12 col-md-3">

      <div class="footer-brand">Little Bom</div>

      <p class="footer-tagline">
        © 2024 Little Bom.<br>
        Crafted for the early years.<br>
        Inspired by nature, built for play.
      </p>

    </div>

    <div class="col-6 col-md-3">

      <div class="footer-heading">Customer Care</div>

      <ul class="footer-links">
        <li><a href="#">Size Guide</a></li>
        <li><a href="#">Shipping</a></li>
        <li><a href="#">Returns</a></li>
      </ul>

    </div>

    <div class="col-6 col-md-3">

      <div class="footer-heading">Brand</div>

      <ul class="footer-links">
        <li><a href="#">Sustainability</a></li>
        <li><a href="#">Privacy</a></li>
      </ul>

    </div>

  </div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/user/productDetail.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Cart - Little Bom</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@300;400;600&display=swap" rel="stylesheet">

  <style>

    :root {
      --color-primary: #8b5e3c;
      --color-bg: #faf9f7;
      --color-surface: #f0ede8;
      --color-border: #e8e4df;
      --color-text: #2c2c2c;
      --color-muted: #8a8680;

      --font-heading: 'Playfair Display', serif;
      --font-body: 'Lato', sans-serif;

      --radius-card: 18px;
      --transition: 0.25s ease;
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
    }

    /* ───────── NAVBAR ───────── */

    .navbar-custom {
      background: var(--color-bg);
      padding: 20px 48px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      border-bottom:1px solid var(--color-border);
      position:sticky;
      top:0;
      z-index:100;
    }

    .navbar-brand-text{
      font-family: var(--font-heading);
      font-size:1.35rem;
      font-weight:700;
      color:var(--color-text);
      text-decoration:none;
    }

    .navbar-links{
      display:flex;
      gap:36px;
    }

    .navbar-links a{
      text-decoration:none;
      color:var(--color-muted);
      font-size:0.78rem;
      letter-spacing:0.1em;
      text-transform:uppercase;
      font-weight:600;
      transition:0.25s ease;
    }

    .navbar-links a:hover,
    .navbar-links a.active{
      color:var(--color-primary);
    }

    .navbar-links a.active{
      border-bottom:2px solid var(--color-primary);
      padding-bottom:2px;
    }

    .navbar-icons{
      display:flex;
      align-items:center;
      gap:20px;
    }

    .navbar-icons a{
      color:var(--color-text);
      font-size:1.1rem;
      text-decoration:none;
    }

    /* ───────── CART SECTION ───────── */

    .cart-section{
      padding:50px 48px 70px;
    }

    .page-title{
      font-family: var(--font-heading);
      font-size:2.8rem;
      margin-bottom:40px;
    }

    .cart-wrapper{
      display:grid;
      grid-template-columns: 1.8fr 0.9fr;
      gap:34px;
      align-items:start;
    }

    /* ───────── CART ITEMS ───────── */

    .cart-card{
      background:white;
      border:1px solid var(--color-border);
      border-radius: var(--radius-card);
      padding:26px;
      margin-bottom:22px;
    }

    .cart-product{
      display:flex;
      gap:22px;
      align-items:center;
    }

    .cart-image{
      width:140px;
      height:140px;
      border-radius:16px;
      overflow:hidden;
      background:#f5f3ef;
      flex-shrink:0;
    }

    .cart-image img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    .cart-details{
      flex:1;
    }

    .product-title{
      font-family: var(--font-heading);
      font-size:1.5rem;
      margin-bottom:10px;
    }

    .product-category{
      color:var(--color-muted);
      font-size:0.85rem;
      margin-bottom:14px;
      text-transform:uppercase;
      letter-spacing:1px;
    }

    .product-price{
      color:var(--color-primary);
      font-size:1.1rem;
      font-weight:700;
      margin-bottom:18px;
    }

    /* Quantity */

    .quantity-wrapper{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .qty-btn{
      width:36px;
      height:36px;
      border:none;
      border-radius:50%;
      background:var(--color-surface);
      font-size:1rem;
      transition:0.25s ease;
    }

    .qty-btn:hover{
      background:var(--color-primary);
      color:white;
    }

    .qty-number{
      font-size:1rem;
      font-weight:600;
      min-width:20px;
      text-align:center;
    }

    .remove-btn{
      color:#b26a5c;
      text-decoration:none;
      font-size:0.9rem;
      margin-top:16px;
      display:inline-block;
    }

    /* ───────── SUMMARY ───────── */

    .summary-card{
      background:white;
      border:1px solid var(--color-border);
      border-radius: var(--radius-card);
      padding:30px;
      position:sticky;
      top:110px;

    }

    .summary-title{
      font-family: var(--font-heading);
      font-size:1.7rem;
      margin-bottom:30px;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      margin-bottom:18px;
      font-size:0.95rem;
    }

    .summary-row.total{
      border-top:1px solid var(--color-border);
      padding-top:20px;
      margin-top:24px;
      font-size:1.1rem;
      font-weight:700;
    }

    .checkout-btn{
      width:100%;
      border:none;
      background:var(--color-primary);
      color:white;
      padding:18px;
      border-radius:50px;
      margin-top:30px;
      font-size:0.82rem;
      letter-spacing:2px;
      text-transform:uppercase;
      font-weight:700;
      transition:0.25s ease;
    }

    .checkout-btn:hover{
      background:#74492d;
    }

    /* ───────── FOOTER ───────── */

    footer{
      background: var(--color-surface);
      padding:56px 48px 32px;
      border-top:1px solid var(--color-border);
      margin-top:60px;
    }

    .footer-brand{
      font-family: var(--font-heading);
      font-size:1.1rem;
      font-weight:700;
      margin-bottom:10px;
    }

    .footer-tagline{
      font-size:0.8rem;
      color:var(--color-muted);
      line-height:1.7;
    }

    .footer-heading{
      font-size:0.72rem;
      letter-spacing:0.12em;
      text-transform:uppercase;
      font-weight:700;
      margin-bottom:18px;
    }

    .footer-links{
      list-style:none;
      padding:0;
    }

    .footer-links li{
      margin-bottom:12px;
    }

    .footer-links a{
      text-decoration:none;
      color:var(--color-muted);
      font-size:0.84rem;
    }

    .footer-links a:hover{
      color:var(--color-primary);
    }

    /* ───────── RESPONSIVE ───────── */

    @media(max-width:991px){

      .cart-wrapper{
        grid-template-columns:1fr;
      }

      .summary-card{
        position:static;
      }

      .navbar-custom,
      .cart-section,
      footer{
        padding-left:24px;
        padding-right:24px;
      }
    }

    @media(max-width:767px){

      .navbar-links{
        display:none;
      }

      .cart-product{
        flex-direction:column;
        align-items:flex-start;
      }

      .cart-image{
        width:100%;
        height:280px;
      }

      .page-title{
        font-size:2rem;
      }
    }

  </style>
</head>

<body>

<!-- NAVBAR -->

 <nav class="navbar-custom" role="navigation" aria-label="Main navigation">
    <a href="/" class="navbar-brand-text">Little Bom</a>
    <div class="navbar-links">
        <a href="/home" class="active" aria-current="page">HOME</a>
        <a href="/shop" class="active" aria-current="page">SHOP</a>
    </div>
   <div class="navbar-icons">
        <a href="/cart" aria-label="Shopping bag"><i class="bi bi-bag"></i></a>
        <a href="/profile" aria-label="Account"><i class="bi bi-person"></i></a>
        <a href="/logout"><i class="bi bi-box-arrow-right"></i> </a>
    </div>
</nav>

<!-- CART SECTION -->

<section class="cart-section">
  <h1 class="page-title">Your Cart</h1>
  <div class="cart-wrapper">

    <!-- LEFT SIDE -->

    <div>

      <!-- PRODUCT 1 -->
 <% if (cartItems.length === 0) { %>
  <p>Your cart is empty.</p>
<% } else { %>
  <% cartItems.forEach(item => { %>
    <div class="cart-card">
      <div class="cart-product">

        <div class="cart-image">
          <img src="<%= item.product.image[0] %>" alt="">
        </div>

        <div class="cart-details">
          <h3 class="product-title"><%= item.product.name %></h3>
          <p class="product-price">₹<%= item.product.price.toFixed(2) %></p>

        <div class="quantity-wrapper" data-id="<%= item.product._id %>">
             <button class="qty-btn minus">-</button>
             <span class="qty-number"><%= item.quantity %></span>
            <button class="qty-btn plus">+</button>
        </div>

             <a href="#" class="remove-btn" data-id="<%= item.product._id %>">
                 <i class="bi bi-trash"></i> Remove
             </a>
        </div>

      </div>
    </div>
  <% }) %>
<% } %>
    </div>

    <!-- RIGHT SIDE -->

    <div class="summary-card">

      <h2 class="summary-title">Order Summary</h2>

      <div class="summary-row">
        <span>Subtotal</span>
       <span class="subtotal-value">₹<%= subtotal.toFixed(2) %></span>
      </div>
      <div class="summary-row">
        <span>Shipping</span>
         <span class="shipping-value">₹<%= shipping.toFixed(2) %></span>
      </div>

   <div class="summary-row total">
     <span>Total</span>
   <span class="grandtotal-value">₹<%= grandTotal.toFixed(2) %></span>
   </div>
    <div class="coupon-wrapper" style="margin-top:20px;">
        <input type="text" id="couponInput" class="form-control" placeholder="Enter coupon code">
        <button id="applyCouponBtn" class="checkout-btn" style="margin-top:10px;">Apply Coupon</button>
        <p id="couponMsg" style="margin-top:8px;font-size:0.85rem;"></p>
    </div>
     <button class="checkout-btn" onclick="window.location.href='/checkout'">
  Proceed To Checkout
</button>

    </div>

  </div>

</section>

<!-- FOOTER -->

<footer>

  <div class="row g-4">

    <div class="col-12 col-md-3">

      <div class="footer-brand">Little Bom</div>

      <p class="footer-tagline">
        © 2024 Little Bom.<br>
        Crafted for the early years.<br>
        Inspired by nature, built for play.
      </p>

    </div>

    <div class="col-6 col-md-3">

      <div class="footer-heading">Customer Care</div>

      <ul class="footer-links">
        <li><a href="#">Size Guide</a></li>
        <li><a href="#">Shipping</a></li>
        <li><a href="#">Returns</a></li>
      </ul>

    </div>

    <div class="col-6 col-md-3">

      <div class="footer-heading">Brand</div>

      <ul class="footer-links">
        <li><a href="#">Sustainability</a></li>
        <li><a href="#">Privacy</a></li>
      </ul>

    </div>

  </div>

</footer>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/user/cart.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders – LittleBom</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@300;400;600;700&display=swap">
  <style>
    :root{
        --primary:#8b5e3c;--bg:#faf9f7;--surface:#f0ede8;--border:#e8e4df;--text:#2c2c2c;--muted:#8a8680;--font-h:'Playfair Display',serif;--font-b:'Lato',sans-serif}
    body{
        font-family:var(--font-b);background:var(--bg);color:var(--text);font-size:14px}
    .navbar-custom{
        background:var(--bg);padding:20px 48px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
    .navbar-brand-text{
        font-family:var(--font-h);font-size:1.35rem;font-weight:700;color:var(--text);text-decoration:none}
    .navbar-icons a{
      color:var(--text);font-size:1.1rem;text-decoration:none;margin-left:20px}
    .page-header{
      padding:32px 48px 0}
    .page-title{
      font-family:var(--font-h);font-size:1.6rem;font-weight:700}
    .page-sub{
      color:var(--muted);font-size:.85rem;margin-top:4px}
    .orders-wrap{
      padding:24px 48px 60px}
    .order-card{
      background:#fff;border-radius:16px;border:1px solid var(--border);margin-bottom:20px;overflow:hidden}
    .order-header{
      padding:16px 20px;background:var(--surface);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
    .order-id{
      font-weight:700;font-size:.85rem}
    .order-date{
      font-size:.78rem;color:var(--muted)}
    .order-body{
      padding:16px 20px}
    .order-item{
      display:flex;gap:14px;padding:10px 0;border-bottom:1px solid var(--surface);align-items:center}
    .order-item:last-child{border-bottom:none}
    .item-img{
      width:52px;height:52px;border-radius:8px;object-fit:cover;background:var(--surface);flex-shrink:0}
    .item-info{
      flex:1}
    .item-name{
      font-weight:700;font-size:.86rem}
    .item-qty{
      font-size:.78rem;color:var(--muted)}
    .item-price{
      font-weight:700;font-size:.86rem;color:var(--primary)}
    .order-footer{
      padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
    .order-total{
      font-weight:700;font-size:.95rem}
    .order-total span{
      color:var(--primary)}
    .badge-status{
      padding:5px 12px;border-radius:50px;font-size:.72rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
    .badge-placed{
      background:#e8f4fd;color:#2471a3}
    .badge-processing{
      background:#fef9e7;color:#d4ac0d}
    .badge-shipped{
      background:#e8f8f5;color:#1e8449}
    .badge-delivered{
      background:#eafaf1;color:#1a5276}
    .badge-cancelled{
      background:#fdedec;color:#c0392b}
    .badge-returned{
      background:#f4ecf7;color:#7d3c98}
    .pay-badge{
      font-size:.75rem;color:var(--muted);display:flex;align-items:center;gap:5px}
    .empty-orders{
      text-align:center;padding:60px 20px;color:var(--muted)}
    .empty-orders i{
      font-size:3rem;display:block;margin-bottom:12px;color:var(--border)}
    .shop-btn{
      display:inline-block;margin-top:16px;padding:10px 24px;background:var(--primary);color:#fff;border-radius:50px;text-decoration:none;font-size:.8rem;font-weight:700;letter-spacing:1px}
    @media(max-width:768px){.navbar-custom,.page-header,.orders-wrap{padding-left:20px;padding-right:20px}}
  </style>
</head>
<body>

<nav class="navbar-custom">
  <a href="/" class="navbar-brand-text">LittleBom</a>
  <div class="navbar-icons">
    <a href="/home"><i class="bi bi-house"></i></a>
    <a href="/shop"><i class="bi bi-grid"></i></a>
    <a href="/cart"><i class="bi bi-bag"></i></a>
    <a href="/profile"><i class="bi bi-person"></i></a>
    <a href="/logout"><i class="bi bi-box-arrow-right"></i></a>
  </div>
</nav>

<div class="page-header">
  <div class="page-title">My Orders</div>
  <div class="page-sub">Track and manage your orders</div>
</div>

<div class="orders-wrap">
  <% if(orders.length === 0) { %>
    <div class="empty-orders">
      <i class="bi bi-bag-x"></i>
      <div>No orders yet!</div>
      <a href="/shop" class="shop-btn">Start Shopping</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
    <div class="order-card">

      <div class="order-header" style="cursor:pointer" onclick="window.location.href='/orders/<%= order._id %>'">
        <div>

          <div class="order-id">Order #<%= order._id.toString().slice(-8).toUpperCase() %></div>
          <div class="order-date"><%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <span class="badge-status badge-<%= order.orderStatus %>"><%= order.orderStatus %></span>
        </div>
      </div>

      <div class="order-body">
        <% order.items.forEach(item => { %>
        <div class="order-item">
          <img class="item-img" src="<%= item.image %>" alt="<%= item.name %>">
          <div class="item-info">
            <div class="item-name"><%= item.name %></div>
            <div class="item-qty">Qty: <%= item.quantity %></div>
          </div>
          <div class="item-price">₹<%= item.price %></div>
        </div>
        <% }) %>
      </div>

      <div class="order-footer">
        <div class="pay-badge">
          <i class="bi bi-<%= order.paymentMethod === 'cod' ? 'cash-coin' : 'credit-card' %>"></i>
          <%= order.paymentMethod === 'cod' ? 'Cash on Delivery' : 'Razorpay' %>
        </div>
        <div class="order-total">Total: <span>₹<%= order.grandTotal.toFixed(2) %></span></div>
      </div>

    </div>
    <% }) %>
  <% } %>
</div>

</body>
</html>
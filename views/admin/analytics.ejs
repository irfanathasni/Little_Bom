<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Analytics – Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .stat-card {
             border-radius: 12px; padding: 20px; color: #fff; margin-bottom: 20px; }
        .card-blue {
             background: linear-gradient(135deg, #2471a3, #1abc9c) }
        .card-green {
             background: linear-gradient(135deg, #1e8449, #2ecc71) }
        .card-orange {
             background: linear-gradient(135deg, #d35400, #f39c12) }
        .card-purple { 
            background: linear-gradient(135deg, #7d3c98, #a569bd) }
        .stat-card h6 { 
            font-size: .75rem; letter-spacing: 1px; text-transform: uppercase; opacity: .85 }
        .stat-card h2 {
             font-size: 1.8rem; font-weight: 700; margin: 6px 0 2px }
        .stat-card p { 
            font-size: .8rem; opacity: .8; margin: 0 }
        .chart-card { 
            background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,.06) }
        .chart-title { 
            font-size: .9rem; font-weight: 700; margin-bottom: 16px; color: #2c2c2c }
        .top-product { 
            display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f0f0f0 }
        .top-product:last-child { 
            border-bottom: none }
        .product-rank { 
            width: 24px; height: 24px; border-radius: 50%; background: #2c2c2c; color: #fff; font-size: .72rem; font-weight: 700; display: flex; align-items: center; justify-content: center }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <%- include('../partials/sidebar') %>
        <div class="col-md-10">
            <div class="topbar d-flex justify-content-between align-items-center p-3">
                <h5 class="mb-0">Analytics & Sales Report</h5>
                <div><span class="me-3">LittleBom</span>
                <a href="/admin/logout" class="btn btn-sm btn-outline-danger">Logout</a></div>
            </div>

            <div class="content mt-3">

                <!-- SUMMARY CARDS -->
                <div class="row">
                    <div class="col-md-3">
                        <div class="stat-card card-blue">
                            <h6>Today's Orders</h6>
                            <h2><%= todayOrders %></h2>
                            <p>Revenue: ₹<%= todayRevenue %></p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card card-green">
                            <h6>This Week</h6>
                            <h2><%= weekOrders %></h2>
                            <p>Revenue: ₹<%= weekRevenue %></p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card card-orange">
                            <h6>This Month</h6>
                            <h2><%= monthOrders %></h2>
                            <p>Revenue: ₹<%= monthRevenue %></p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card card-purple">
                            <h6>Total Orders</h6>
                            <h2><%= totalOrders %></h2>
                            <p>Revenue: ₹<%= totalRevenue %></p>
                        </div>
                    </div>
                </div>

                <!-- CHARTS ROW -->
                <div class="row">
                    <!-- Bar Chart — Monthly Revenue -->
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="chart-title">Monthly Revenue (Bar)</div>
                            <canvas id="barChart"></canvas>
                        </div>
                    </div>
                    <!-- Line Chart — Monthly Orders -->
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="chart-title">Monthly Orders (Line)</div>
                            <canvas id="lineChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Pie Chart — Order Status -->
                    <div class="col-md-5">
                        <div class="chart-card">
                            <div class="chart-title">Order Status (Pie)</div>
                            <canvas id="pieChart"></canvas>
                        </div>
                    </div>
                    <!-- Top 5 Products -->
                    <div class="col-md-7">
                        <div class="chart-card">
                            <div class="chart-title">Top 5 Most Sold Products</div>
                            <% topProducts.forEach((product, index) => { %>
                            <div class="top-product">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="product-rank"><%= index + 1 %></div>
                                    <div style="font-weight:600;font-size:.88rem"><%= product._id %></div>
                                </div>
                                <div style="font-weight:700;color:#2471a3"><%= product.totalSold %> sold</div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
<!-- Daily + Weekly Charts -->
                <div class="row">
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="chart-title">Daily Revenue — Last 7 Days</div>
                            <canvas id="dailyChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="chart-title">Weekly Revenue — Last 8 Weeks</div>
                            <canvas id="weeklyChart"></canvas>
                        </div>
                    </div>
                </div>

            </div> 
        </div>     
    </div>      
</div>           
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script> 
    const monthlySales = <%- JSON.stringify(monthlySales) %>;
    const statusData = <%- JSON.stringify(statusData) %>;
    const dailySales = <%- JSON.stringify(dailySales) %>;
    const weeklySales = <%- JSON.stringify(weeklySales) %>;
</script>
<script src="/js/analytics.js"></script>
</body>
</html>
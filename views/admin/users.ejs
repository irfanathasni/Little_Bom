<body>

<div class="container-fluid">
    <div class="row">

        <!-- 🔹 Sidebar -->
          <%- include('../partials/sidebar') %>
        <!-- 🔹 Main Section -->
        <div class="col-md-10">

            <!-- 🔸 Topbar -->
            <div class="topbar d-flex justify-content-between align-items-center p-3">
                <h5 class="mb-0">User Management</h5>

                <div>
                    <span class="me-3">LittleBom</span>
                    <a href="/admin/logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </div>
            </div>

            <!-- 🔸 Content -->
            <div class="content mt-3">

                <!-- Table Card -->
                <div class="card shadow-sm p-4">

                    <h5 class="mb-4">All Users</h5>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">

                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                <% users.forEach((user, index) => { %>

                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td><%= user.name %></td>
                                        <td><%= user.email %></td>

                                        <!-- Status -->
                                        <td>
                                            <% if(user.isBlocked){ %>
                                                <span class="badge bg-danger">Blocked</span>
                                            <% } else { %>
                                                <span class="badge bg-success">Active</span>
                                            <% } %>
                                        </td>

                                        <!-- Action -->
                                        <td class="text-center">
                                            <button 
                                                class="blockBtn btn btn-sm <%= user.isBlocked ? 'btn-success' : 'btn-danger' %>"
                                                data-id="<%= user._id %>"
                                                data-blocked="<%= user.isBlocked %>">

                                                <%= user.isBlocked ? "Unblock" : "Block" %>
                                            </button>
                                        </td>

                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>
                    </div>

                </div>

            </div>

        </div>

    </div>
</div>
 <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- External JS -->
<script src="/js/userManagement.js"></script>
</body>

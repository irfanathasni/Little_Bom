<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Orders Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<div class="container-fluid">
    <div class="row">

        <!-- Sidebar -->
        <%- include('../partials/sidebar') %>

        <!-- Main Section -->
        <div class="col-md-10">

            <!-- Topbar -->
            <div class="topbar d-flex justify-content-between align-items-center p-3">
                <h5 class="mb-0">Orders Management</h5>
                <div>
                    <span class="me-3">LittleBom</span>
                    <a href="/admin/logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </div>
            </div>

            <!-- Content -->
            <div class="content mt-3">
                <div class="card shadow-sm p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0">All Orders</h5>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Payment</th>
                                    <th>Status</th>
                                    <th>Update Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach((order, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>#<%= order._id.toString().slice(-8).toUpperCase() %></td>
                                    <td>
                                        <div style="font-weight:600"><%= order.userId ? order.userId.name : 'Unknown' %></div>
                                        <div style="font-size:.75rem;color:#888"><%= order.userId ? order.userId.email : '' %></div>
                                    </td>
                                    <td><%= new Date(order.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                                    <td>₹<%= order.grandTotal %></td>
                                    <td><%= order.paymentMethod === 'cod' ? 'COD' : 'Razorpay' %></td>
                                    <td>
                                        <span class="badge <%= 
                                            order.orderStatus === 'placed' ? 'bg-primary' :
                                            order.orderStatus === 'processing' ? 'bg-warning text-dark' :
                                            order.orderStatus === 'shipped' ? 'bg-info text-dark' :
                                            order.orderStatus === 'delivered' ? 'bg-success' :
                                            order.orderStatus === 'cancelled' ? 'bg-danger' :
                                            'bg-secondary' %>">
                                            <%= order.orderStatus %>
                                        </span>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm" style="width:140px"
                                            onchange="updateStatus('<%= order._id %>', this.value)">
                                            <option value="">-- Update --</option>
                                            <option value="placed">Placed</option>
                                            <option value="processing">Processing</option>
                                            <option value="shipped">Shipped</option>
                                            <option value="delivered">Delivered</option>
                                            <option value="cancelled">Cancelled</option>
                                        </select>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/orderManagement.js"></script>
</body>
</html>